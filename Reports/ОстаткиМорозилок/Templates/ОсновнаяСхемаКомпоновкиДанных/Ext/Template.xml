		<query>ВЫБРАТЬ
	Ост.Морозилка КАК Морозилка,
	Морозилки.ИнвентарныйНомер КАК ИнвНомер,
	Морозилки.ЗаводскойНомер КАК ЗавНомер,
	Морозилки.ТипМК КАК ТипМК,
	Ост.ТипМеста КАК ТипМеста,
	Ост.МестоОбъект КАК МестоОбъект,
	СУММА(Ост.КоличествоОстаток) КАК Количество,
	ВЫБОР
		КОГДА Ост.МестоОбъект.Родитель = ЗНАЧЕНИЕ(Справочник.Партнеры.ПустаяСсылка)
			ТОГДА Ост.МестоОбъект
		ИНАЧЕ Ост.МестоОбъект.Родитель
	КОНЕЦ КАК ГоловнойПартнер,
	Морозилки.ЗалоговаяСтоимость КАК ЗалоговаяСтоимость,
	Морозилки.ДатаВыпуска КАК ДатаВыпуска
ПОМЕСТИТЬ Вт
ИЗ
	РегистрНакопления.ОстаткиМорозилок.Остатки({(&amp;Период)}, ) КАК Ост
		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Морозилки КАК Морозилки
		ПО Ост.Морозилка = Морозилки.Ссылка

СГРУППИРОВАТЬ ПО
	Ост.Морозилка,
	Морозилки.ИнвентарныйНомер,
	Морозилки.ЗаводскойНомер,
	Морозилки.ТипМК,
	Ост.ТипМеста,
	Ост.МестоОбъект,
	ВЫБОР
		КОГДА Ост.МестоОбъект.Родитель = ЗНАЧЕНИЕ(Справочник.Партнеры.ПустаяСсылка)
			ТОГДА Ост.МестоОбъект
		ИНАЧЕ Ост.МестоОбъект.Родитель
	КОНЕЦ,
	Морозилки.ЗалоговаяСтоимость,
	Морозилки.ДатаВыпуска
;

