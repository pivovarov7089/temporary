// Количество повторных проверок заполнения ОСУ перед штатным завершением подбора.
&НаКлиенте
Перем Расш1_КоличествоПопытокАвтозавершения;

&НаКлиенте
Процедура Расш1_ЗапуститьАвтозавершениеПодбора(ИнтервалПослеЗаполнения = Неопределено) Экспорт
	
	Расш1_КоличествоПопытокАвтозавершения = 0;
	Если ИнтервалПослеЗаполнения = Неопределено Тогда
		ИнтервалПослеЗаполнения = Расш1_ИнтервалПовторнойПопыткиАвтозавершения();
	КонецЕсли;
	
	ОтключитьОбработчикОжидания("Расш1_ЗавершитьПодборПослеЗаполнения");
	
	ЗаполнитьКоличествоПоДокументуОСУКлиент();
	
	ПодключитьОбработчикОжидания("Расш1_ЗавершитьПодборПослеЗаполнения", ИнтервалПослеЗаполнения, Истина);
	
КонецПроцедуры

&НаКлиенте
Процедура Расш1_ЗавершитьПодборПослеЗаполнения() Экспорт
	
	Расш1_КоличествоПопытокАвтозавершения = Расш1_КоличествоПопытокАвтозавершения + 1;
	
	Если Расш1_ЕстьНезаполненноеКоличествоОСУ() Тогда
		
		Если Расш1_КоличествоПопытокАвтозавершения < Расш1_МаксимальноеКоличествоПопытокАвтозавершения() Тогда
			ПодключитьОбработчикОжидания(
				"Расш1_ЗавершитьПодборПослеЗаполнения",
				Расш1_ИнтервалПовторнойПопыткиАвтозавершения(),
				Истина);
		КонецЕсли;
		
		Возврат;
		
	КонецЕсли;
	
	ПроверкаЗавершенаКлиент();
	
КонецПроцедуры

&НаКлиенте
Функция Расш1_МаксимальноеКоличествоПопытокАвтозавершения()
	
	// BSLLS:disable-next-line MagicNumber
	Возврат 10;
	
КонецФункции

&НаКлиенте
Функция Расш1_ИнтервалПовторнойПопыткиАвтозавершения()
	
	// BSLLS:disable-next-line MagicNumber
	Возврат 2;
	
КонецФункции

&НаКлиенте
Функция Расш1_ЕстьНезаполненноеКоличествоОСУ()
	
	Для Каждого СтрокаМаркируемойПродукции Из ПодобраннаяМаркируемаяПродукция Цикл
		
		Если ЗначениеЗаполнено(СтрокаМаркируемойПродукции.Номенклатура)
			И СтрокаМаркируемойПродукции.Количество > СтрокаМаркируемойПродукции.КоличествоПодобрано Тогда
			Возврат Истина;
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Ложь;
	
КонецФункции
