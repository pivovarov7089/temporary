
// Клиентские переменные модуля формы — для тонкого клиента нужна директива &НаКлиенте, иначе «переменная не определена».

&НаКлиенте
Перем ФормаДокументаВладелецПодбораМаркировки;

&НаКлиенте
Перем ПараметрыПодбораДляПовторногоОткрытия;

#Область ОбработчикиСобытийФормы

&НаКлиенте
Процедура ПриОткрытии(Отказ)

	УстановитьДоступностьПоляАвтозавершения();

КонецПроцедуры

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)

	ДатаНачала           = НачалоДня(ТекущаяДатаСеанса());
	ДатаОкончания        = КонецДня(ТекущаяДатаСеанса());
	ОбрабатыватьВетИС    = Истина;
	ОбрабатыватьБезВетИС = Истина;
	ПропускатьОформленные = Истина;
	// По умолчанию выкл.: штатное «Завершить проверку» УТ может удалить неподобранные строки молока по виду.
	АвтозавершатьПодбор   = Ложь;
	ИнтервалАвтозавершенияСек = 12;
	ИнтервалСторожаСек       = 90;
	СостояниеОбработки   = НСтр("ru = 'Готово к работе'");
	ОбработкаАктивна     = Ложь;
	ТекущийИндексДокумента = 0;
	ОжидаемОтветОтФормы  = Ложь;

	Элементы.ОстановитьОбработку.Доступность = Ложь;
	Элементы.НачатьОбработку.Доступность      = Истина;
	Элементы.КнопкаЗаполнить.Доступность      = Истина;

КонецПроцедуры

#КонецОбласти

&НаКлиенте
Процедура АвтозавершатьПодборПриИзменении(Элемент)

	УстановитьДоступностьПоляАвтозавершения();

КонецПроцедуры

#Область ОбработчикиКоманд

&НаКлиенте
Процедура НормализоватьИнтервалыТаймеров()

	Если ЭтотОбъект.ИнтервалАвтозавершенияСек < 3 Тогда
		ЭтотОбъект.ИнтервалАвтозавершенияСек = 3;
	КонецЕсли;

	МинимумСторожа = Макс(30, ЭтотОбъект.ИнтервалАвтозавершенияСек + 10);
	Если ЭтотОбъект.ИнтервалСторожаСек < МинимумСторожа Тогда
		ЭтотОбъект.ИнтервалСторожаСек = МинимумСторожа;
	КонецЕсли;

КонецПроцедуры

// Заполнение таблицы документов реализации за выбранный период.
&НаКлиенте
Процедура ЗаполнитьДокументы(Команда)

	Если НЕ ЗначениеЗаполнено(ДатаНачала) Тогда
		ПоказатьПредупреждение(, НСтр("ru = 'Укажите дату начала периода.'"));
		Возврат;
	КонецЕсли;

	СостояниеОбработки = НСтр("ru = 'Загрузка документов...'");
	ЗаполнитьДокументыНаСервере();
	СостояниеОбработки = СтрШаблон(НСтр("ru = 'Найдено: %1 реализаций'"), ТаблицаДокументов.Количество());

КонецПроцедуры

// Запуск последовательной обработки документов.
&НаКлиенте
Процедура НачатьОбработку(Команда)

	Если ТаблицаДокументов.Количество() = 0 Тогда
		ПоказатьПредупреждение(, НСтр("ru = 'Сначала заполните список документов (кнопка ""Заполнить"").'"));
		Возврат;
	КонецЕсли;

	Если НЕ ОбрабатыватьВетИС И НЕ ОбрабатыватьБезВетИС Тогда
		ПоказатьПредупреждение(, НСтр("ru = 'Выберите хотя бы один вид продукции для обработки.'"));
		Возврат;
	КонецЕсли;

	// Сбрасываем флаги обработки
	Для Каждого Строка Из ТаблицаДокументов Цикл
		Строка.ВетИСОбработан    = Ложь;
		Строка.БезВетИСОбработан = Ложь;
	КонецЦикла;

	ЖурналОбработки.Очистить();
	ТекущийИндексДокумента = 0;
	ОбработкаАктивна       = Истина;
	ОжидаемОтветОтФормы    = Ложь;
	ПараметрыПодбораДляПовторногоОткрытия = Неопределено;
	ФормаДокументаВладелецПодбораМаркировки = Неопределено;

	// Сбрасываем клиентский ПовтИсп-кэш, чтобы УчитываемыеВидыМаркируемойПродукции
	// вернул актуальные данные из БД, а не устаревшие значения из начала сессии.
	ОбновитьПовторноИспользуемыеЗначения();

	НормализоватьИнтервалыТаймеров();

	УстановитьДоступностьЭлементов(Ложь);
	СостояниеОбработки = НСтр("ru = 'Идет обработка...'");

	// Запускаем через таймер, чтобы все дальнейшие шаги шли через event loop (нет рекурсии)
	ОтключитьОбработчикОжидания("ОбработатьСледующийДокумент");
	ПодключитьОбработчикОжидания("ОбработатьСледующийДокумент", 0.2, Истина);

КонецПроцедуры

// Остановка обработки.
&НаКлиенте
Процедура ОстановитьОбработку(Команда)

	ОбработкаАктивна    = Ложь;
	ОжидаемОтветОтФормы = Ложь;

	// Отменяем все запланированные таймеры
	ОтключитьОбработчикОжидания("ОбработатьСледующийДокумент");
	ОтключитьОбработчикОжидания("ВодСтражникФормыПодбора");
	ОтключитьОбработчикОжидания("ЗавершитьПодборАвтоматически");
	ПараметрыПодбораДляПовторногоОткрытия = Неопределено;
	ФормаДокументаВладелецПодбораМаркировки = Неопределено;

	СостояниеОбработки = НСтр("ru = 'Остановлено пользователем'");
	УстановитьДоступностьЭлементов(Истина);

КонецПроцедуры

#КонецОбласти

#Область СерверныеПроцедуры

&НаСервере
Процедура ЗаполнитьДокументыНаСервере()

	ТаблицаДокументов.Очистить();

	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Реал.Ссылка        КАК Ссылка,
	|	Реал.Дата          КАК Дата,
	|	Реал.Номер         КАК Номер,
	|	Реал.Партнер       КАК Партнер,
	|	Реал.Организация   КАК Организация,
	|	Реал.Склад         КАК Склад
	|ИЗ
	|	Документ.РеализацияТоваровУслуг КАК Реал
	|ГДЕ
	|	Реал.Дата МЕЖДУ &ДатаНач И &ДатаКон
	|	И Реал.Проведен
	|	И НЕ Реал.ПометкаУдаления
	|УПОРЯДОЧИТЬ ПО
	|	Реал.Дата";

	Запрос.УстановитьПараметр("ДатаНач", НачалоДня(ДатаНачала));
	Запрос.УстановитьПараметр("ДатаКон", КонецДня(ДатаОкончания));

	Выборка = Запрос.Выполнить().Выбрать();

	Пока Выборка.Следующий() Цикл

		НоваяСтрока = ТаблицаДокументов.Добавить();
		НоваяСтрока.Выбор           = Истина;
		НоваяСтрока.Ссылка          = Выборка.Ссылка;
		НоваяСтрока.Дата            = Выборка.Дата;
		НоваяСтрока.Номер           = Выборка.Номер;
		НоваяСтрока.Контрагент      = Строка(Выборка.Партнер);
		НоваяСтрока.Организация     = Выборка.Организация;
		НоваяСтрока.Склад           = Выборка.Склад;
		НоваяСтрока.ВетИСОбработан    = Ложь;
		НоваяСтрока.БезВетИСОбработан = Ложь;

		ВидВетИС    = Перечисления.ВидыПродукцииИС.МолочнаяПродукцияПодконтрольнаяВЕТИС;
		ВидБезВетИС = Перечисления.ВидыПродукцииИС.МолочнаяПродукцияБезВЕТИС;

		НоваяСтрока.СтатусВетИС    = ТекстСтатусаОформленияПоВиду(Выборка.Ссылка, ВидВетИС);
		НоваяСтрока.СтатусБезВетИС = ТекстСтатусаОформленияПоВиду(Выборка.Ссылка, ВидБезВетИС);

	КонецЦикла;

КонецПроцедуры

// Возвращает статус оформления маркировки ИСМП по документу-основанию и виду продукции (одна маркировка на вид).
//
// Параметры:
//   ДокументОснование - ДокументСсылка.РеализацияТоваровУслуг
//   ВидПродукции      - ПеречислениеСсылка.ВидыПродукцииИС
//
// Возвращаемое значение:
//   ПеречислениеСсылка.СтатусыОформленияДокументовГосИС, Неопределено
&НаСервере
Функция СтатусОформленияМаркировкиПоВидуПродукции(ДокументОснование, ВидПродукции)

	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	Статусы.СтатусОформления КАК Статус
	|ИЗ
	|	РегистрСведений.СтатусыОформленияДокументовИСМП КАК Статусы
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.МаркировкаТоваровИСМП КАК Маркировка
	|		ПО Статусы.Документ = Маркировка.Ссылка
	|ГДЕ
	|	Статусы.Основание = &Основание
	|	И Маркировка.ВидПродукции = &ВидПродукции
	|	И НЕ Статусы.Архивный
	|
	|УПОРЯДОЧИТЬ ПО
	|	Маркировка.Дата УБЫВ";

	Запрос.УстановитьПараметр("Основание",     ДокументОснование);
	Запрос.УстановитьПараметр("ВидПродукции", ВидПродукции);

	Результат = Запрос.Выполнить();
	Если Результат.Пустой() Тогда
		Возврат Неопределено;
	КонецЕсли;

	Выборка = Результат.Выбрать();
	Выборка.Следующий();
	Возврат Выборка.Статус;

КонецФункции

// Статус оформления в виде строки для отображения в таблице.
&НаСервере
Функция ТекстСтатусаОформленияПоВиду(ДокументСсылка, ВидПродукции)

	Статус = СтатусОформленияМаркировкиПоВидуПродукции(ДокументСсылка, ВидПродукции);
	Если Статус = Неопределено Тогда
		Возврат "";
	КонецЕсли;

	Возврат Строка(Статус);

КонецФункции

// Истина — по данным регистра обмен с ГИС МТ по этому виду завершён, повторно не требуется.
&НаСервере
Функция ОформлениеПоВидуСчитатьЗавершённым(Статус)

	Если Статус = Неопределено Тогда
		Возврат Ложь;
	КонецЕсли;

	Возврат Статус = Перечисления.СтатусыОформленияДокументовГосИС.Оформлено
		Или Статус = Перечисления.СтатусыОформленияДокументовГосИС.НеТребуется;

КонецФункции

// Проверка, можно ли пропустить ветку (уже оформлено по выбранному виду молока).
&НаСервере
Функция ОформлениеВидаУжеГотовоНаСервере(ДокументСсылка, ЭтоВетИС)

	ВидПродукции = ?(ЭтоВетИС,
		Перечисления.ВидыПродукцииИС.МолочнаяПродукцияПодконтрольнаяВЕТИС,
		Перечисления.ВидыПродукцииИС.МолочнаяПродукцияБезВЕТИС);

	Статус = СтатусОформленияМаркировкиПоВидуПродукции(ДокументСсылка, ВидПродукции);
	Возврат ОформлениеПоВидуСчитатьЗавершённым(Статус);

КонецФункции

// Возвращает ФиксированнаяСтруктура параметров указания серий для РеализацияТоваровУслуг.
//
// Параметры:
//   ДокументСсылка - ДокументСсылка.РеализацияТоваровУслуг
//
// Возвращаемое значение:
//   ФиксированнаяСтруктура - параметры указания серий, аналогично форме документа
&НаСервере
Функция ПолучитьПараметрыУказанияСерийНаСервере(ДокументСсылка)

	Объект = ДокументСсылка.ПолучитьОбъект();
	Возврат Новый ФиксированнаяСтруктура(НоменклатураСервер.ПараметрыУказанияСерий(Объект, Документы.РеализацияТоваровУслуг));

КонецФункции

// Проверяет, разрешён ли учёт вида маркируемой продукции.
//
// Параметры:
//   ВидПродукции - ПеречислениеСсылка.ВидыПродукцииИС
//
// Возвращаемое значение:
//   Булево - Истина, если вид продукции есть в списке учитываемых
&НаСервере
Функция ВестиУчетПродукцииВРегистреНаСервере(ВидПродукции)

	УчитываемыеВиды = ОбщегоНазначенияИСМПВызовСервера.УчитываемыеВидыМаркируемойПродукции();
	Возврат УчитываемыеВиды.Найти(ВидПродукции) <> Неопределено;

КонецФункции

// Проверяет наличие маркируемых товаров указанного вида в документе реализации.
//
// Параметры:
//   ДокументСсылка          - ДокументСсылка.РеализацияТоваровУслуг
//   ВидМаркируемойПродукции - ПеречислениеСсылка.ВидыПродукцииИС
//
// Возвращаемое значение:
//   Булево - Истина, если в документе есть товары данного вида маркируемой продукции
&НаСервере
Функция ЕстьМаркируемыеТоварыВДокументеНаСервере(ДокументСсылка, ВидМаркируемойПродукции)

	ТекстЗапроса =
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
	|	ИСТИНА КАК ЕстьТовары
	|ИЗ
	|	Документ.РеализацияТоваровУслуг.Товары КАК Товары
	|	ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК СправочникНоменклатура
	|		ПО Товары.Номенклатура = СправочникНоменклатура.Ссылка
	|ГДЕ
	|	Товары.Ссылка = &Ссылка
	|	И &УсловиеМаркируемаяПродукция";

	ИнтеграцияИСМПУТ.УстановитьУсловиеПоВидуМаркируемойПродукции(ТекстЗапроса, ВидМаркируемойПродукции);

	Запрос = Новый Запрос(ТекстЗапроса);
	Запрос.УстановитьПараметр("Ссылка", ДокументСсылка);
	Возврат НЕ Запрос.Выполнить().Пустой();

КонецФункции

// Обновляет статус оформления конкретной строки таблицы документов.
//
// Параметры:
//   ИндексСтроки - Число - индекс строки в ТаблицаДокументов
&НаСервере
Процедура ОбновитьСтатусСтрокиНаСервере(ИндексСтроки)

	Строка = ТаблицаДокументов[ИндексСтроки];
	ВидВетИС    = Перечисления.ВидыПродукцииИС.МолочнаяПродукцияПодконтрольнаяВЕТИС;
	ВидБезВетИС = Перечисления.ВидыПродукцииИС.МолочнаяПродукцияБезВЕТИС;

	Строка.СтатусВетИС    = ТекстСтатусаОформленияПоВиду(Строка.Ссылка, ВидВетИС);
	Строка.СтатусБезВетИС = ТекстСтатусаОформленияПоВиду(Строка.Ссылка, ВидБезВетИС);

КонецПроцедуры

#КонецОбласти

#Область ПоследовательнаяОбработкаДокументов

// Основной цикл: обрабатывает следующий доступный документ из таблицы.
// Вызывается через ПодключитьОбработчикОжидания, поэтому должна быть Экспорт.
&НаКлиенте
Процедура ОбработатьСледующийДокумент() Экспорт

	Попытка
		ОбработатьСледующийДокументВнутри();
	Исключение

		// Исключение из ПриОткрытии формы подбора — гасим и продолжаем
		ОтключитьОбработчикОжидания("ВодСтражникФормыПодбора");
		ОтключитьОбработчикОжидания("ЗавершитьПодборАвтоматически");
		ОжидаемОтветОтФормы = Ложь;
		ПараметрыПодбораДляПовторногоОткрытия = Неопределено;
		ФормаДокументаВладелецПодбораМаркировки = Неопределено;

		Если ОбработкаАктивна И ТекущийИндексДокумента < ТаблицаДокументов.Количество() Тогда

			Строка       = ТаблицаДокументов[ТекущийИндексДокумента];
			ТекстОшибки  = КраткоеПредставлениеОшибки(ИнформацияОбОшибке());
			ЭтапВетИС    = ОбрабатыватьВетИС И НЕ Строка.ВетИСОбработан;

			ДобавитьЗаписьВЖурнал(Строка.Ссылка, НСтр("ru = 'Ошибка (перехвачена)'"), ТекстОшибки);
			ОтметитьЭтапОбработан(ТекущийИндексДокумента, ЭтапВетИС);

		Иначе
			ЗавершитьОбработку();
		КонецЕсли;

	КонецПопытки;

КонецПроцедуры

// Внутренняя реализация основного цикла обработки.
&НаКлиенте
Процедура ОбработатьСледующийДокументВнутри()

	Если НЕ ОбработкаАктивна Тогда
		ЗавершитьОбработку();
		Возврат;
	КонецЕсли;

	Пока ТекущийИндексДокумента < ТаблицаДокументов.Количество() Цикл

		Строка = ТаблицаДокументов[ТекущийИндексДокумента];

		Если НЕ Строка.Выбор Тогда
			ТекущийИндексДокумента = ТекущийИндексДокумента + 1;
			Продолжить;
		КонецЕсли;

		// Определяем, что нужно обработать для данного документа
		НужноВетИС    = ОбрабатыватьВетИС    И НЕ Строка.ВетИСОбработан;
		НужноБезВетИС = ОбрабатыватьБезВетИС И НЕ Строка.БезВетИСОбработан;

		Если ПропускатьОформленные Тогда

			Если НужноВетИС И ОформлениеВидаУжеГотовоНаСервере(Строка.Ссылка, Истина) Тогда

				ДобавитьЗаписьВЖурнал(Строка.Ссылка, НСтр("ru = 'Подбор ВетИС'"),
					НСтр("ru = 'Пропущено: по ВетИС маркировка уже оформлена в ИС МП'"));
				ОтметитьЭтапОбработан(ТекущийИндексДокумента, Истина);
				Возврат;

			КонецЕсли;

			Если НужноБезВетИС И ОформлениеВидаУжеГотовоНаСервере(Строка.Ссылка, Ложь) Тогда

				ДобавитьЗаписьВЖурнал(Строка.Ссылка, НСтр("ru = 'Подбор без ВетИС'"),
					НСтр("ru = 'Пропущено: без ВетИС маркировка уже оформлена в ИС МП'"));
				ОтметитьЭтапОбработан(ТекущийИндексДокумента, Ложь);
				Возврат;

			КонецЕсли;

		КонецЕсли;

		Если НужноВетИС Тогда
			ОткрытьФормуПодбора(ТекущийИндексДокумента, Истина);
			Возврат;

		ИначеЕсли НужноБезВетИС Тогда
			ОткрытьФормуПодбора(ТекущийИндексДокумента, Ложь);
			Возврат;

		Иначе
			// Оба типа для этого документа обработаны — переходим к следующему
			ОбновитьСтатусСтрокиНаСервере(ТекущийИндексДокумента);
			ТекущийИндексДокумента = ТекущийИндексДокумента + 1;

		КонецЕсли;

	КонецЦикла;

	ЗавершитьОбработку();

КонецПроцедуры

// Открывает форму подбора маркировки для указанного документа.
//
// Параметры:
//   ИндексСтроки - Число  - индекс строки в ТаблицаДокументов
//   ЭтоВетИС     - Булево - Истина для подконтрольной ВетИС, Ложь для без ВетИС
&НаКлиенте
Процедура ОткрытьФормуПодбора(ИндексСтроки, ЭтоВетИС)

	Строка = ТаблицаДокументов[ИндексСтроки];

	ВидПродукции = ?(ЭтоВетИС,
		ПредопределенноеЗначение("Перечисление.ВидыПродукцииИС.МолочнаяПродукцияПодконтрольнаяВЕТИС"),
		ПредопределенноеЗначение("Перечисление.ВидыПродукцииИС.МолочнаяПродукцияБезВЕТИС"));

	ТекстДействия = ?(ЭтоВетИС, НСтр("ru = 'Подбор ВетИС'"), НСтр("ru = 'Подбор без ВетИС'"));

	// Превентивная проверка 1: учёт данного вида продукции должен быть включён в регистре
	Если НЕ ВестиУчетПродукцииВРегистреНаСервере(ВидПродукции) Тогда

		ДобавитьЗаписьВЖурнал(Строка.Ссылка, ТекстДействия,
			НСтр("ru = 'Пропущено: учёт данного вида продукции отключён в регистре настроек'"));
		ОтметитьЭтапОбработан(ИндексСтроки, ЭтоВетИС);
		Возврат;

	КонецЕсли;

	// Превентивная проверка 2: в документе должны быть товары нужного вида маркируемой продукции
	Если НЕ ЕстьМаркируемыеТоварыВДокументеНаСервере(Строка.Ссылка, ВидПродукции) Тогда

		ДобавитьЗаписьВЖурнал(Строка.Ссылка, ТекстДействия,
			НСтр("ru = 'Пропущено: нет товаров данного вида маркируемой продукции в документе'"));
		ОтметитьЭтапОбработан(ИндексСтроки, ЭтоВетИС);
		Возврат;

	КонецЕсли;

	ДобавитьЗаписьВЖурнал(Строка.Ссылка, ТекстДействия, НСтр("ru = 'Открываем форму подбора...'"));

	СостояниеОбработки = СтрШаблон(НСтр("ru = 'Обрабатывается %1 / %2 — %3'"),
		ТекущийИндексДокумента + 1, ТаблицаДокументов.Количество(), ТекстДействия);

	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("ПроверяемыйДокумент",                      Строка.Ссылка);
	ПараметрыФормы.Вставить("Организация",                              Строка.Организация);
	ПараметрыФормы.Вставить("Склад",                                    Строка.Склад);
	ПараметрыФормы.Вставить("ВидМаркируемойПродукции",                  ВидПродукции);
	ПараметрыФормы.Вставить("РежимПодбораСуществующихУпаковок",         Истина);
	ПараметрыФормы.Вставить("ПриЗавершенииСохранятьРезультатыПроверки", Ложь);
	ПараметрыФормы.Вставить("ПроверкаНеПоДокументу",                    Ложь);
	ПараметрыФормы.Вставить("КонтролироватьСканируемуюПродукциюПоДокументуОснованию", Ложь);
	ПараметрыФормы.Вставить("РедактированиеФормыНедоступно",            Ложь);
	ПараметрыФормы.Вставить("ПроверятьНеобходимостьПеремаркировки",     Истина);
	ПараметрыФормы.Вставить("РасчитыватьХешСуммуУпаковок",              Истина);
	ПараметрыФормы.Вставить("ДоступноСозданиеНовыхУпаковок",            Ложь);
	ПараметрыФормы.Вставить("ДоступнаПечатьЭтикеток",                   Ложь);
	ПараметрыФормы.Вставить("ПроверкаЭлектронногоДокумента",            Ложь);
	ПараметрыФормы.Вставить("ИспользоватьСтатусПроверкаЗавершена",      Ложь);
	ПараметрыФормы.Вставить("Сценарий",                                  0);
	ПараметрыФормы.Вставить("РежимИсправленияОшибокПослеПередачиКодов", Ложь);
	ПараметрыФормы.Вставить("ПараметрыУказанияСерий",
		ПолучитьПараметрыУказанияСерийНаСервере(Строка.Ссылка));

	// Шаг 1: открываем форму документа реализации как промежуточного владельца.
	// Форма подбора маркировки ожидает в качестве ВладелецФормы форму конкретного
	// документа (РеализацияТоваровУслуг), из которой читает ПараметрыИнтеграцийГосИС.
	ФормаДокумента = ОткрытьФорму(
		"Документ.РеализацияТоваровУслуг.Форма.ФормаДокумента",
		Новый Структура("Ключ", Строка.Ссылка),
		ЭтаФорма,
		,
		,
		,
		,
		РежимОткрытияОкнаФормы.Независимый);

	Если ФормаДокумента = Неопределено Тогда

		ДобавитьЗаписьВЖурнал(Строка.Ссылка, ТекстДействия,
			НСтр("ru = 'Пропущено: форма документа реализации не открылась'"));
		ОтметитьЭтапОбработан(ИндексСтроки, ЭтоВетИС);
		Возврат;

	КонецЕсли;

	ФормаДокументаВладелецПодбораМаркировки = ФормаДокумента;

	ДопПараметры = Новый Структура("ИндексСтроки,ЭтоВетИС,ТекстДействия,ФормаДокумента",
		ИндексСтроки, ЭтоВетИС, ТекстДействия, ФормаДокумента);

	Оповещение = Новый ОписаниеОповещения(
		"ПослеЗакрытияФормыПодбора", ЭтотОбъект, ДопПараметры);

	// Шаг 2: открываем форму подбора с формой документа как владельцем.
	// Ключ уникальности = УникальныйИдентификатор нашей формы.
	// Копия параметров на клиенте: повторный вызов ОткрытьФорму с ПУСТЫМИ параметрами по тому же ключу
	// сбрасывает форму и даёт «В форму не передан вид маркируемой продукции».
	ПараметрыПодбораДляПовторногоОткрытия = ОбщегоНазначенияКлиентСервер.СкопироватьСтруктуру(ПараметрыФормы);

	Попытка

		ОткрытьФорму(
			"Обработка.ПроверкаИПодборПродукцииИСМП.Форма.ПроверкаИПодбор",
			ПараметрыФормы,
			ФормаДокумента,
			ЭтаФорма.УникальныйИдентификатор,
			,
			,
			Оповещение,
			РежимОткрытияОкнаФормы.Независимый);

	Исключение

		// ОткрытьФорму синхронно выбросила исключение — закрываем форму документа и продолжаем
		ОжидаемОтветОтФормы = Ложь;
		ПараметрыПодбораДляПовторногоОткрытия = Неопределено;
		ФормаДокументаВладелецПодбораМаркировки = Неопределено;
		ФормаДокумента.Закрыть();

		ТекстОшибки = КраткоеПредставлениеОшибки(ИнформацияОбОшибке());
		ДобавитьЗаписьВЖурнал(Строка.Ссылка, ТекстДействия,
			СтрШаблон(НСтр("ru = 'Пропущено (ошибка): %1'"), ТекстОшибки));

		ОтметитьЭтапОбработан(ИндексСтроки, ЭтоВетИС);
		Возврат;

	КонецПопытки;

	// Запускаем сторожевой таймер, если форма не закрылась вовремя — принудительно продолжаем
	ОжидаемОтветОтФормы = Истина;
	ОтключитьОбработчикОжидания("ВодСтражникФормыПодбора");
	ПодключитьОбработчикОжидания("ВодСтражникФормыПодбора", ЭтотОбъект.ИнтервалСторожаСек);

	// Автозавершение: имитирует «Завершить подбор» в УТ; без загрузки ИС МП и полного подбора может снять неподобранные
	// строки маркируемой продукции текущего вида — поэтому только по флагу и при интервале больше 0.
	ОтключитьОбработчикОжидания("ЗавершитьПодборАвтоматически");
	Если ЭтотОбъект.АвтозавершатьПодбор И ЭтотОбъект.ИнтервалАвтозавершенияСек > 0 Тогда
		ПодключитьОбработчикОжидания("ЗавершитьПодборАвтоматически", ЭтотОбъект.ИнтервалАвтозавершенияСек, Истина);
	КонецЕсли;

КонецПроцедуры

// По таймеру: повторно открывает форму подбора с ТЕМИ ЖЕ параметрами (ключ уникальности),
// получает ссылку на уже открытое окно и вызывает ОтветНаВопросПриЗавершенииПроверки.
// Нельзя вызывать ОткрытьФорму с пустой структурой параметров — форма теряет вид маркируемой продукции.
&НаКлиенте
Процедура ЗавершитьПодборАвтоматически() Экспорт

	Если НЕ ЭтотОбъект.АвтозавершатьПодбор Тогда
		Возврат;
	КонецЕсли;

	Если НЕ ОжидаемОтветОтФормы Тогда
		// Форма уже закрылась до срабатывания таймера — всё в порядке
		Возврат;
	КонецЕсли;

	ПараметрыПовторногоВхода = ПараметрыПодбораДляПовторногоОткрытия;
	Если ПараметрыПовторногоВхода = Неопределено Или ТипЗнч(ПараметрыПовторногоВхода) <> Тип("Структура") Тогда
		Возврат;
	КонецЕсли;

	ФормаПодбора = ОткрытьФорму(
		"Обработка.ПроверкаИПодборПродукцииИСМП.Форма.ПроверкаИПодбор",
		ПараметрыПовторногоВхода,
		ФормаДокументаВладелецПодбораМаркировки,
		ЭтаФорма.УникальныйИдентификатор,
		,
		,
		,
		РежимОткрытияОкнаФормы.Независимый);

	Если ФормаПодбора = Неопределено Тогда
		// Форма не найдена (закрылась), ПослеЗакрытия должен был сработать
		Возврат;
	КонецЕсли;

	ДобавитьЗаписьВЖурнал(
		ТаблицаДокументов[ТекущийИндексДокумента].Ссылка,
		НСтр("ru = 'Автозавершение'"),
		НСтр("ru = 'Инициируем завершение подбора...'"));

	// Формируем ответ на вопрос "как учитывать непроверенные позиции":
	// ВНаличии — для реализации все позиции документа присутствуют (они продаются).
	// ОтветНаВопросПриЗавершенииПроверки — экспортная процедура формы подбора (Экспорт).
	// Она маркирует непроверенные как "ВНаличии", запускает ЗавершитьПроверку →
	// НачатьЗавершениеПроверки (длительная операция → ГИС МТ), форма закрывается.
	РезультатВопроса = Новый Структура("КакУчитыватьНеПроверенныеОтложенные",
		ПредопределенноеЗначение("Перечисление.СтатусыПроверкиНаличияПродукцииИС.ВНаличии"));

	Попытка
		ФормаПодбора.ОтветНаВопросПриЗавершенииПроверки(РезультатВопроса, Неопределено);
	Исключение
		ТекстОшибки = КраткоеПредставлениеОшибки(ИнформацияОбОшибке());
		ДобавитьЗаписьВЖурнал(
			ТаблицаДокументов[ТекущийИндексДокумента].Ссылка,
			НСтр("ru = 'Автозавершение'"),
			СтрШаблон(НСтр("ru = 'Ошибка завершения: %1'"), ТекстОшибки));
		// Сторожевой таймер (45 сек) продолжит работу и разблокирует обработку
	КонецПопытки;

КонецПроцедуры

// Сторожевой таймер: если форма не вызвала колбэк в течение 45 секунд — принудительно продолжаем.
&НаКлиенте
Процедура ВодСтражникФормыПодбора() Экспорт

	ОтключитьОбработчикОжидания("ВодСтражникФормыПодбора");
	ОтключитьОбработчикОжидания("ЗавершитьПодборАвтоматически");

	Если НЕ ОжидаемОтветОтФормы Тогда
		Возврат; // Колбэк уже был вызван нормально — всё в порядке
	КонецЕсли;

	ОжидаемОтветОтФормы = Ложь;
	ПараметрыПодбораДляПовторногоОткрытия = Неопределено;
	ФормаДокументаВладелецПодбораМаркировки = Неопределено;

	Строка = ТаблицаДокументов[ТекущийИндексДокумента];
	ДобавитьЗаписьВЖурнал(Строка.Ссылка, НСтр("ru = 'Сторожевой таймер'"), СтрШаблон(
		НСтр("ru = 'Форма не ответила за %1 с — продолжаем обработку'"), ЭтотОбъект.ИнтервалСторожаСек));

	ЭтапВетИС = ОбрабатыватьВетИС И НЕ Строка.ВетИСОбработан;
	ОтметитьЭтапОбработан(ТекущийИндексДокумента, ЭтапВетИС);

КонецПроцедуры

// Обработчик закрытия формы подбора маркировки.
//
// Параметры:
//   РезультатЗакрытия - Произвольный - результат закрытия формы
//   ДопПараметры      - Структура     - контекст: ИндексСтроки, ЭтоВетИС, ТекстДействия, ФормаДокумента
&НаКлиенте
Процедура ПослеЗакрытияФормыПодбора(РезультатЗакрытия, ДопПараметры) Экспорт

	// Отменяем таймеры — форма закрылась штатно
	ОтключитьОбработчикОжидания("ВодСтражникФормыПодбора");
	ОтключитьОбработчикОжидания("ЗавершитьПодборАвтоматически");
	ОжидаемОтветОтФормы = Ложь;
	ПараметрыПодбораДляПовторногоОткрытия = Неопределено;
	ФормаДокументаВладелецПодбораМаркировки = Неопределено;

	ИндексСтроки  = ДопПараметры.ИндексСтроки;
	ЭтоВетИС      = ДопПараметры.ЭтоВетИС;
	ТекстДействия = ДопПараметры.ТекстДействия;
	ФормаДокумента = ДопПараметры.ФормаДокумента;

	// Закрываем форму документа реализации, которая была открыта как промежуточный владелец
	Если ФормаДокумента <> Неопределено Тогда

		Попытка
			ФормаДокумента.Закрыть();
		Исключение
			// Форма уже закрыта или недоступна — игнорируем
		КонецПопытки;

	КонецЕсли;

	Строка = ТаблицаДокументов[ИндексСтроки];

	// Определяем текст результата по значению, возвращённому формой
	Если РезультатЗакрытия = Истина Тогда
		ТекстРезультата = НСтр("ru = 'Завершено, данные отправлены'");
	ИначеЕсли ТипЗнч(РезультатЗакрытия) = Тип("Структура") И ЗначениеЗаполнено(РезультатЗакрытия) Тогда
		ТекстРезультата = НСтр("ru = 'Завершено'");
	Иначе
		ТекстРезультата = НСтр(
			"ru = 'Форма закрыта без завершения (часто: нет ЭП пользователя для организации в ИС МТ или отказ при подписи).'");
	КонецЕсли;

	ДобавитьЗаписьВЖурнал(Строка.Ссылка, ТекстДействия, ТекстРезультата);

	// Помечаем этап как обработанный и продолжаем
	ОтметитьЭтапОбработан(ИндексСтроки, ЭтоВетИС);

КонецПроцедуры

// Завершает обработку, восстанавливает доступность элементов формы.
&НаКлиенте
Процедура ЗавершитьОбработку()

	ОбработкаАктивна = Ложь;

	Обработано = 0;
	Для Каждого Строка Из ТаблицаДокументов Цикл

		Если Строка.ВетИСОбработан Или Строка.БезВетИСОбработан Тогда
			Обработано = Обработано + 1;
		КонецЕсли;

	КонецЦикла;

	СостояниеОбработки = СтрШаблон(НСтр("ru = 'Готово. Обработано: %1 документов'"), Обработано);
	УстановитьДоступностьЭлементов(Истина);

КонецПроцедуры

#КонецОбласти

#Область ВспомогательныеПроцедуры

// Помечает этап (ВетИС или Без ВетИС) как обработанный и планирует переход к следующему шагу.
//
// Параметры:
//   ИндексСтроки - Число  - индекс строки в ТаблицаДокументов
//   ЭтоВетИС     - Булево - Истина для этапа ВетИС, Ложь для Без ВетИС
&НаКлиенте
Процедура ОтметитьЭтапОбработан(ИндексСтроки, ЭтоВетИС)

	Строка = ТаблицаДокументов[ИндексСтроки];

	Если ЭтоВетИС Тогда
		Строка.ВетИСОбработан = Истина;
	Иначе
		Строка.БезВетИСОбработан = Истина;
	КонецЕсли;

	ОбновитьСтатусСтрокиНаСервере(ИндексСтроки);

	// Следующий шаг через таймер — чистый event loop, нет рекурсии и нет блокировки UI
	ОтключитьОбработчикОжидания("ОбработатьСледующийДокумент");
	ПодключитьОбработчикОжидания("ОбработатьСледующийДокумент", 0.2, Истина);

КонецПроцедуры

// Добавляет строку в журнал обработки.
//
// Параметры:
//   ДокументСсылка - ДокументСсылка - ссылка на документ реализации
//   Действие       - Строка          - описание выполняемого действия
//   Результат      - Строка          - результат действия
&НаКлиенте
Процедура ДобавитьЗаписьВЖурнал(ДокументСсылка, Действие, Результат)

	НоваяЗапись = ЖурналОбработки.Добавить();
	// BSLLS:disable-next-line DeprecatedCurrentDate
	НоваяЗапись.Время     = ТекущаяДата();
	НоваяЗапись.Документ  = Строка(ДокументСсылка);
	НоваяЗапись.Действие  = Действие;
	НоваяЗапись.Результат = Результат;

	// Прокручиваем журнал до последней записи
	Элементы.ЖурналОбработки.ТекущаяСтрока = НоваяЗапись.ПолучитьИдентификатор();

КонецПроцедуры

// Устанавливает доступность кнопок управления.
//
// Параметры:
//   ДоступноНачало - Булево - Истина если доступны кнопки "Заполнить" и "Начать"
&НаКлиенте
Процедура УстановитьДоступностьПоляАвтозавершения()

	Если ОбработкаАктивна Тогда
		Элементы.ИнтервалАвтозавершенияСек.Доступность = Ложь;
	Иначе
		Элементы.ИнтервалАвтозавершенияСек.Доступность = ЭтотОбъект.АвтозавершатьПодбор;
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура УстановитьДоступностьЭлементов(ДоступноНачало)

	Элементы.НачатьОбработку.Доступность     = ДоступноНачало;
	Элементы.ОстановитьОбработку.Доступность  = НЕ ДоступноНачало;
	Элементы.КнопкаЗаполнить.Доступность      = ДоступноНачало;
	Элементы.ДатаНачала.Доступность           = ДоступноНачало;
	Элементы.ДатаОкончания.Доступность        = ДоступноНачало;
	Элементы.ЧекАвтозавершатьПодбор.Доступность  = ДоступноНачало;
	Элементы.ИнтервалСторожаСек.Доступность      = ДоступноНачало;
	УстановитьДоступностьПоляАвтозавершения();
	Если НЕ ДоступноНачало Тогда
		Элементы.ИнтервалАвтозавершенияСек.Доступность = Ложь;
	КонецЕсли;

КонецПроцедуры

#КонецОбласти
