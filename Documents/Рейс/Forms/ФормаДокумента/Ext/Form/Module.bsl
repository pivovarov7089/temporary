// Формирует файл Excel по макету документа "Рейс" (МакетExcel).
// Требуются области макета: Шапка, Заголовки, Организация, Группа, Строка, ПустаяСтрока
// Параметры в областях (из твоего скрина):
//  Шапка: <Заголовок>
//  Организация: <ИНН>, <Организация>, <ОбщееКоличество>
//  Группа: <Группа>
//  Строка: <Код>, <количество>, <Наименование>, <Заявка>
//
// РезультатЗапроса должен иметь поля:
//  Организация, Родитель, НоменклатураКод, НоменклатураНаименование,
//  ЕдиницаИзмеренияНаименование, Количество
//
// Возвращает полный путь к XLSX (fallback в XLS)
&НаСервереБезКонтекста
Функция СформироватьExcelЧерезМакет(СсылкаРейса, РезультатЗапроса, Дата) Экспорт
	
	КаталогВрем = КаталогВременныхФайлов();
	ИмяОсн      = Транслит(Лев(СсылкаРейса.ЗонаДоставки.Наименование, 6)) + "_" + СсылкаРейса.Номер;
	ФайлXLSX    = КаталогВрем + ИмяОсн + ".xlsx";
	ФайлXLS     = КаталогВрем + ИмяОсн + ".xls";
	
	ТД    = Новый ТабличныйДокумент;
	Макет = Документы.Рейс.ПолучитьМакет("МакетExcel"); // макет документа
	
	// ---- Шапка
	Обл = Макет.ПолучитьОбласть("Шапка");
	Обл.Параметры.Заголовок = "Заявка " + Формат(Дата, "ДЛФ=DD.MM.YY");
	ТД.Вывести(Обл);
	
	// ---- Заголовки колонок
	ТД.Вывести(Макет.ПолучитьОбласть("Заголовки"));
	
	// ---- Данные: Партнёр → Группа → Позиции
	ВыбОрганизация = РезультатЗапроса.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам, "Организация");
	Пока ВыбОрганизация.Следующий() Цикл
		
		// Партнёр
		ОблП = Макет.ПолучитьОбласть("Организация");
		ОблП.Параметры.ИНН= ВыбОрганизация.ОрганизацияИНН; // если нужно ИНН — подставь здесь свою логику
		ОблП.Параметры.Организация = Строка(ВыбОрганизация.Организация);
		//ОблП.Параметры.ОбщееКоличество = ВыбОрганизация.Количество;
		ТД.Вывести(ОблП);
		
		// Группы
		ВыбГруппа = ВыбОрганизация.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам, "Родитель");
		Пока ВыбГруппа.Следующий() Цикл
			
			ИмяГруппы = ?(ПустаяСтрока(Строка(ВыбГруппа.Родитель)), "(Без группы)", Строка(ВыбГруппа.Родитель));
			ОблГ = Макет.ПолучитьОбласть("Группа");
			ОблГ.Параметры.Группа = ИмяГруппы;
			ТД.Вывести(ОблГ);
			
			// Позиции
			ВыбПоз = ВыбГруппа.Выбрать();
			Пока ВыбПоз.Следующий() Цикл
				ОблСтр = Макет.ПолучитьОбласть("Строка");
				ОблСтр.Параметры.Код = ?(ЗначениеЗаполнено(ВыбПоз.НоменклатураКод), ВыбПоз.НоменклатураКод, "");
				ОблСтр.Параметры.Количество = Формат(ВыбПоз.Количество, "ЧГ=0");
				ОблСтр.Параметры.Наименование = ВыбПоз.НоменклатураНаименование;
				ОблСтр.Параметры.Заявка = Формат(ВыбПоз.КоличествоУпаковок, "ЧГ=0") + " " + ВыбПоз.НаименованиеУпаковки;
				ТД.Вывести(ОблСтр);
			КонецЦикла;
			
			// Пустая строка после группы
			//ТД.Вывести(Макет.ПолучитьОбласть("ПустаяСтрока"));
		КонецЦикла;
		
		// Пустая строка между партнёрами
		ТД.Вывести(Макет.ПолучитьОбласть("ПустаяСтрока"));
	КонецЦикла;
	
	// ---- Сохранение
	Попытка
		ТД.Записать(ФайлXLSX, ТипФайлаТабличногоДокумента.XLSX);
		Возврат ФайлXLSX;
	Исключение
		ТД.Записать(ФайлXLS, ТипФайлаТабличногоДокумента.XLS);
		Возврат ФайлXLS;
	КонецПопытки;
	
КонецФункции

// SMTP: по твоей схеме (ИнтернетПочтовыйПрофиль / ИнтернетПочтовоеСообщение)
&НаСервереБезКонтекста
Процедура ОтправитьЧерезSMTP(ПолноеИмяФайла, Тема, ТекстПисьма, Получатель) Экспорт
	Пользователь	  = "alfa.ooo.zakaz@yandex.ru";
	Пароль		      = "pqliyqdsixipldww";
	Отправитель       = "alfa.ooo.zakaz";
	
	ПараметрыПочты = Новый ИнтернетПочтовыйПрофиль;
	ПараметрыПочты.АдресСервераSMTP = "smtp.yandex.ru";
	ПараметрыПочты.АутентификацияSMTP = СпособSMTPАутентификации.ПоУмолчанию;
	ПараметрыПочты.ПользовательSMTP = Пользователь;
	ПараметрыПочты.ПарольSMTP = Пароль;
	ПараметрыПочты.АутентификацияSMTP = СпособSMTPАутентификации.Login;
	ПараметрыПочты.ПортSMTP = 587; 
	
	// Данные IMAP
	ПараметрыПочты.АдресСервераIMAP = "imap.yandex.ru";
	ПараметрыПочты.ИспользоватьSSLIMAP = Истина;
	ПараметрыПочты.ПортIMAP = 993;
	ПараметрыПочты.ПользовательIMAP = Пользователь;
	ПараметрыПочты.ПарольIMAP = Пароль;
	
	Письмо = Новый ИнтернетПочтовоеСообщение;
	Письмо.Тема = Тема;
	Текст = Письмо.Тексты.Добавить(ТекстПисьма);
	Текст.ТипТекста = ТипТекстаПочтовогоСообщения.ПростойТекст;
	Письмо.ИмяОтправителя = Отправитель;
	Письмо.Отправитель = Пользователь;
	
	Письмо.Получатели.Добавить(Получатель);
	
	Письмо.Вложения.Добавить(ПолноеИмяФайла);
	
	Подключение = Новый ИнтернетПочта;
	Попытка
		Подключение.Подключиться(ПараметрыПочты);
		Подключение.Послать(Письмо);
		
		Подключение.Подключиться(ПараметрыПочты, ПротоколИнтернетПочты.IMAP);
		//Подключение.ТекущийПочтовыйЯщик = "sent";
		Подключение.Послать(Письмо,, ПротоколИнтернетПочты.IMAP);
	Исключение
		ВызватьИсключение "SMTP: " + ОписаниеОшибки();
	КонецПопытки;
КонецПроцедуры

// ===================== СЕРВЕР: запросы =====================

// Заказы, включенные в рейс (ТЧ документа)
&НаСервереБезКонтекста
Функция ЗапросЗаказыРейса(СсылкаРейса) Экспорт
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	РЗ.ЗаказКлиента КАК ЗаказКлиента
	|ИЗ
	|	Документ.РейсПоставки.Заказы КАК РЗ
	|ГДЕ
	|	РЗ.Ссылка = &Ссылка");
	Запрос.УстановитьПараметр("Ссылка", СсылкаРейса);
	Возврат Запрос;
КонецФункции

// Диапазон дат выбранных заказов
&НаСервереБезКонтекста
Функция ЗапросДиапазонДат(СписокЗаказов) Экспорт
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	МИН(ЗК.Дата) КАК ДатаНач,
	|	МАКС(ЗК.Дата) КАК ДатаКон
	|ИЗ
	|	Документ.ЗаказКлиента КАК ЗК
	|ГДЕ
	|	ЗК.Ссылка В (&Заказы)");
	Запрос.УстановитьПараметр("Заказы", СписокЗаказов);
	Возврат Запрос;
КонецФункции


&НаКлиенте
Процедура ПечатьПакетаДокументов(Команда)
	
	Если ЭтотОбъект.Модифицированность Тогда
		Сообщить("Сначала запишите рейс."); 
		Возврат;
	КонецЕсли;
	
	
	ТабДокМаршрут = СформироватьТабДокМаршрутногоЛиста(); // твоя функция
	ТабДокМаршрут.ДвусторонняяПечать = ТипДвустороннейПечати.ПереворотВлево;
	ТабДокМаршрут.Напечатать(РежимИспользованияДиалогаПечати.НеИспользовать);
	
	//// 2) Запросить у сервера, что и в каком виде печатать по всем заказам
	//МассивДоков = СобратьПечатьПоРейсуСервер(Объект.Ссылка);
	//Если МассивДоков = Неопределено ИЛИ МассивДоков.Количество() = 0 Тогда
	//	Сообщить("Нет заказов для печати.");
	//	Возврат;
	//КонецЕсли;
	
	
	Если Объект.Заказы.Количество() = 0 Тогда
		Сообщить("Нет заказов для печати.");
		Возврат;
	КонецЕсли;
	
	МассивЗаказов = МассивЗаказовКлиента(Объект.Ссылка);
	
	НомерСтроки = 1;
	Для каждого Стр из МассивЗаказов Цикл
		ПечатьПакетаПоЗаказу(Стр, НомерСтроки);
		НомерСтроки = НомерСтроки + 1;
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Функция МассивЗаказовКлиента(Рейс)
		
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ЗаказКлиентаДок.Ссылка КАК ЗаказКлиента
		|ИЗ
		|	Документ.Рейс.Заказы КАК РейсЗаказы
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ЗаказКлиента КАК ЗаказКлиентаДок
		|		ПО РейсЗаказы.ЗаказКлиента = ЗаказКлиентаДок.Ссылка
		|		И РейсЗаказы.Ссылка = &Рейс
		|
		|УПОРЯДОЧИТЬ ПО
		|	ЗаказКлиента.Номер,
		|	ЗаказКлиента.Дата";
	
	Запрос.УстановитьПараметр("Рейс", Объект.Ссылка);
	РезультатЗапроса = Запрос.Выполнить();
	
	Возврат РезультатЗапроса.Выгрузить().ВыгрузитьКолонку("ЗаказКлиента");
КонецФункции

&НаСервере
Функция СобратьПечатьПоРейсуСервер(СсылкаРейса) Экспорт
	
	Результат = Новый Массив;
	
	// Подтянем строки ТЧ "Заказы" и сами заказы клиентов
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|   Заказы.ЗаказКлиента КАК Заказ
	|ИЗ
	|   Документ.Рейс.Заказы КАК Заказы
	|ГДЕ
	|   Заказы.Ссылка = &Рейс");
	Запрос.УстановитьПараметр("Рейс", СсылкаРейса);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	МассивДоков = Новый Массив;
	Пока Выборка.Следующий() Цикл 
		МассивДоков.Добавить(Выборка.Заказ);
	КонецЦикла;
	
	Возврат МассивДоков;
	
КонецФункции

&НаСервере
Функция НужноПечататьПКО(ЗаказКлиента)
	Если ЗаказКлиента.ФормаОплаты = Перечисления.ФормыОплаты.Наличная
		И ЗаказКлиента.ЭтапыГрафикаОплаты.Количество() > 0
		И ЗаказКлиента.ЭтапыГрафикаОплаты[0].Сдвиг = 0 Тогда
		Возврат Истина
	Иначе Возврат Ложь
	КонецЕсли;
КонецФункции

&НаКлиенте
Процедура ПечатьПакетаПоЗаказу(ЗаказКлиента, НомерСтроки)
	
	
	//Поиск данных 
	Если Не ЗначениеЗаполнено(ЗаказКлиента) Тогда
		Сообщить("Не выбран заказ."); Возврат;
	КонецЕсли;
	
	Реализации = НайтиРеализацииПоЗаказуСервер(ЗаказКлиента);
	Если Реализации = Неопределено Или Реализации.Количество() = 0 Тогда
		Сообщить("Нет проведённых Реализаций по этому заказу — печатать нечего.");
		Возврат;
	КонецЕсли;
	
	СФ = НайтиСФПоРТИСервер(Реализации);
	Если СФ = Неопределено Или СФ.Количество() = 0 Тогда
		Сообщить("Нет проведённых СФ по этому заказу — печатать нечего.");
		Возврат;
	КонецЕсли;
	
	
	
	//Блок печати Реализации
	Сп = Новый СписокЗначений;
	Для каждого Стр из Реализации Цикл
		Сп.Добавить(Стр);
	КонецЦикла;
	
	ТабДок = ПолучитьТабДокРеализации(Реализации, Сп, НомерСтроки);
	ТабДок.ОриентацияСтраницы = ОриентацияСтраницы.Портрет;
	ТабДок.Напечатать(РежимИспользованияДиалогаПечати.НеИспользовать);
	
	//Блок печати УПД
	СФДляУПД = Новый Массив;
	Для каждого СФСтр из СФ Цикл
		СФДляУПД.Добавить(СФСтр);
	КонецЦикла;
	
	Если СФДляУПД.Количество() > 0 Тогда
		ПечатьИнтересно(ЭтотОбъект.Элементы.Заказы,  КомандыПечатиСФУПД(), СФДляУПД);
	КонецЕсли;
	
	//Блок печати ПКО
	Если НужноПечататьПКО(ЗаказКлиента) Тогда
		ПКОДляПечати = Новый Массив;
		ПКО = НайтиПКОПоРеализацииСервер(Реализации);
		
		Сп = Новый СписокЗначений;
		Для каждого Стр из ПКО Цикл
			Сп.Добавить(Стр);
		КонецЦикла;
		ТабДок = СформироватьПечатнуюФормуКО1(ПКО, Сп);
		ТабДок.Напечатать(РежимИспользованияДиалогаПечати.НеИспользовать);
	КонецЕсли;
	
	// Повторная печать УПД
	ПечатьИнтересно(ЭтотОбъект.Элементы.Заказы,  КомандыПечатиСФУПД(), СФДляУПД);
	
	// Дополнительные невостребованные печати
	//ПечатьИнтересно(ЭтотОбъект.Элементы.Заказы, КомандыПечатиРтиТорг12(), Реализации);
	//ПечатьИнтересно(ЭтотОбъект.Элементы.Заказы, КомандыПечатиРтиСчетНаОплату(), Реализации);
	//ПечатьИнтересно(ЭтотОбъект.Элементы.Заказы,  КомандыПечатиСФСФ(), СФ);

КонецПроцедуры  

&НаСервере
Функция ПолучитьТабДокРеализации(Реализации, Сп, НомерСтроки)
	ПараметрыПечатиНакладной = Новый Структура;
	ПараметрыПечатиНакладной.Вставить("НомерСтрокиРейс", НомерСтроки);
	Возврат Документы.РеализацияТоваровУслуг.Расш1_СформироватьПечатнуюФормуНакладная(Реализации, Сп, ПараметрыПечатиНакладной);
КонецФункции

Функция СформироватьПечатнуюФормуКО1(МассивОбъектов, ОбъектыПечати)
	
	ТабличныйДокумент = Новый ТабличныйДокумент;
	ТабличныйДокумент.КлючПараметровПечати = "ПАРАМЕТРЫ_ПЕЧАТИ_КО1";
	Макет = УправлениеПечатью.МакетПечатнойФормы("Документ.ПриходныйКассовыйОрдер.ПФ_MXL_КО1_ru");
	Макет.КодЯзыка = Метаданные.Языки.Русский.КодЯзыка;
	
	ИспользуетсяРеглУчет = ПолучитьФункциональнуюОпцию("ИспользоватьРеглУчет") И НЕ ПолучитьФункциональнуюОпцию("УправлениеТорговлей");
	
	ТекстЗапроса = 
	"ВЫБРАТЬ
	|	ДанныеДокумента.Ссылка КАК Ссылка,
	|	ЕСТЬNULL(ДанныеДокумента.ИсправляемыйДокумент.Дата, ДанныеДокумента.Дата) КАК ДатаДокумента,
	|	ЕСТЬNULL(ДанныеДокумента.ИсправляемыйДокумент.Номер, ДанныеДокумента.Номер) КАК Номер,
	|	ДанныеДокумента.Организация.Наименование КАК НаименованиеОрганизации,
	|	ДанныеДокумента.Организация.НаименованиеСокращенное КАК НаименованиеОрганизацииСокращенное,
	|	ДанныеДокумента.Организация.Префикс КАК Префикс,
	|	ДанныеДокумента.Организация.ВалютаРегламентированногоУчета КАК ВалютаРегламентированногоУчета,
	|	ВЫБОР 
	|		КОГДА ДанныеДокумента.Валюта = ДанныеДокумента.Организация.ВалютаРегламентированногоУчета
	|			ТОГДА ""50.01""
	|		ИНАЧЕ ""50.21""
	|	КОНЕЦ КАК КодДебета,
	|	ДанныеДокумента.Касса.КассоваяКнига.СтруктурноеПодразделение КАК ПредставлениеПодразделения,
	|	ДанныеДокумента.Контрагент КАК Контрагент,
	|	ДанныеДокумента.Контрагент.Представление КАК КонтрагентПредставление,
	|	ДанныеДокумента.ПринятоОт КАК ПринятоОт,
	|	ДанныеДокумента.Основание КАК Основание,
	|	ДанныеДокумента.Приложение КАК Приложение,
	|	ДанныеДокумента.ВТомЧислеНДС КАК ВТомЧисле,
	|	ДанныеДокумента.СуммаДокумента КАК Сумма,
	|	ДанныеДокумента.Валюта КАК Валюта,
	|	ДанныеДокумента.Валюта.Представление КАК ВалютаПредставление,
	|	ДанныеДокумента.Организация.КодПоОКПО КАК ОрганизацияПоОКПО,
	|	ВЫБОР
	|		КОГДА ДанныеДокумента.Кассир = ЗНАЧЕНИЕ(Справочник.ФизическиеЛица.ПустаяСсылка)
	|			ТОГДА ДанныеДокумента.Автор.ФизическоеЛицо
	|		ИНАЧЕ ДанныеДокумента.Кассир
	|	КОНЕЦ КАК Кассир,
	|	ТаблицаОтветственныеЛица.ГлавныйБухгалтерНаименование КАК ГлавныйБухгалтер,
	|	ДанныеДокумента.ХозяйственнаяОперация КАК ХозяйственнаяОперация,
	|	ДанныеДокумента.СтатьяДвиженияДенежныхСредств КАК СтатьяДвиженияДенежныхСредств
	|ИЗ
	|	Документ.ПриходныйКассовыйОрдер КАК ДанныеДокумента
	|		ЛЕВОЕ СОЕДИНЕНИЕ ТаблицаОтветственныеЛица КАК ТаблицаОтветственныеЛица
	|		ПО ДанныеДокумента.Ссылка = ТаблицаОтветственныеЛица.Ссылка
	|ГДЕ
	|	ДанныеДокумента.Ссылка В(&МассивДокументов)
	|
	|УПОРЯДОЧИТЬ ПО
	|	Номер
	|;";
	
	Если Не ИспользуетсяРеглУчет Тогда
		ТекстЗапроса = ТекстЗапроса + "
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ВложенныйЗапрос.Ссылка,
		|	ВложенныйЗапрос.СтатьяДвиженияДенежныхСредств,
		|	СтатьиДвиженияДенежныхСредств.КорреспондирующийСчет КАК КорСчетКод
		|ИЗ
		|	(ВЫБРАТЬ РАЗЛИЧНЫЕ
		|		ДанныеДокумента.Ссылка КАК Ссылка,
		|		ДанныеДокумента.СтатьяДвиженияДенежныхСредств КАК СтатьяДвиженияДенежныхСредств
		|	ИЗ
		|		Документ.ПриходныйКассовыйОрдер КАК ДанныеДокумента
		|	ГДЕ
		|		ДанныеДокумента.Ссылка В(&МассивДокументов)
		|	
		|	ОБЪЕДИНИТЬ
		|	
		|	ВЫБРАТЬ РАЗЛИЧНЫЕ
		|		РасшифровкаПлатежа.Ссылка,
		|		РасшифровкаПлатежа.СтатьяДвиженияДенежныхСредств
		|	ИЗ
		|		Документ.ПриходныйКассовыйОрдер.РасшифровкаПлатежа КАК РасшифровкаПлатежа
		|	ГДЕ
		|		РасшифровкаПлатежа.Ссылка В(&МассивДокументов)) КАК ВложенныйЗапрос
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.СтатьиДвиженияДенежныхСредств КАК СтатьиДвиженияДенежныхСредств
		|		ПО ВложенныйЗапрос.СтатьяДвиженияДенежныхСредств = СтатьиДвиженияДенежныхСредств.Ссылка
		|
		|УПОРЯДОЧИТЬ ПО
		|	КорреспондирующийСчет";
	КонецЕсли;
	
	Запрос = Новый Запрос(ТекстЗапроса);
	
	МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	ОтветственныеЛицаСервер.СформироватьВременнуюТаблицуОтветственныхЛицДокументов(МассивОбъектов, МенеджерВременныхТаблиц);
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	
	Запрос.УстановитьПараметр("МассивДокументов", МассивОбъектов);
	
	
	РеквизитыСторон = ДенежныеСредстваСервер.СведенияОПолучателеПлательщикеПоДокументам(МассивОбъектов);
	
	МассивРезультатов = Запрос.ВыполнитьПакет();
	Выборка           = МассивРезультатов[0].Выбрать();
	КорСчета          = МассивРезультатов[1].Выгрузить();
	
	ПервыйДокумент = Истина;
	Пока Выборка.Следующий() Цикл
		
		Если Не ПервыйДокумент Тогда
			ТабличныйДокумент.ВывестиГоризонтальныйРазделительСтраниц();
		КонецЕсли;
		ПервыйДокумент = Ложь;
		
		НомерСтрокиНачало = ТабличныйДокумент.ВысотаТаблицы + 1;
		
		ОбластьМакета = Макет.ПолучитьОбласть("Шапка");
		ШтрихкодированиеПечатныхФорм.ВывестиШтрихкодВТабличныйДокумент(ТабличныйДокумент, Макет, ОбластьМакета, Выборка.Ссылка);
		ОбластьМакета.Параметры.Заполнить(Выборка);
		
		// Наименование сокращенное получателя
		ОтборНаименования = Новый Структура("Документ, Признак", Выборка.Ссылка, 4);
		СведенияОНаименовании = РеквизитыСторон.НайтиСтроки(ОтборНаименования);
		
		Если СведенияОНаименовании.Количество() > 0 Тогда
			ОбластьМакета.Параметры.ПредставлениеОрганизации = СведенияОНаименовании[0].ЗначениеРеквизита;
		Иначе
			ОбластьМакета.Параметры.ПредставлениеОрганизации = Выборка.НаименованиеОрганизации;
		КонецЕсли;
		
		Сумма = Формат(Выборка.Сумма, "ЧДЦ=2");
		Если Выборка.ВалютаРегламентированногоУчета <> Выборка.Валюта Тогда
			Сумма = Сумма + " " + СокрЛП(Выборка.ВалютаПредставление);
		КонецЕсли;
		ОбластьМакета.Параметры.Сумма = Сумма;
		ОбластьМакета.Параметры.СуммаРубКоп = ФормированиеПечатныхФорм.СуммаРубКоп(
			Выборка.Сумма, 
			Выборка.Валюта,	
			Выборка.ВалютаРегламентированногоУчета);
		Если Выборка.Валюта <> Выборка.ВалютаРегламентированногоУчета Тогда
			ОбластьМакета.Параметры.СуммаРубКоп = ОбластьМакета.Параметры.СуммаРубКоп + " " + СокрЛП(Выборка.ВалютаПредставление); 
		КонецЕсли;
		ОбластьМакета.Параметры.СуммаПрописью = РаботаСКурсамиВалютУТ.СформироватьСуммуПрописью(
			Выборка.Сумма, 
			Выборка.Валюта, 
			Ложь); // ВыводитьСуммуБезКопеек
		ОбластьМакета.Параметры.НомерДокумента = ПрефиксацияОбъектовКлиентСервер.НомерНаПечать(
			Выборка.Номер, 
			Ложь,
			Истина);
		ОбластьМакета.Параметры.СубСчет = КорреспондирующийСчет(Выборка, КорСчета, ИспользуетсяРеглУчет);
		
		Если ПустаяСтрока(Выборка.ВТомЧисле) Тогда
			ОбластьМакета.Параметры.ВТомЧисле = НСтр("ru='без налога (НДС)'", Метаданные.Языки.Русский.КодЯзыка);
		КонецЕсли;
		
		ОбластьМакета.Параметры.ФИОГлавногоБухгалтера = Выборка.ГлавныйБухгалтер;
		ОбластьМакета.Параметры.ФИОКассира = ФизическиеЛицаУТ.ФамилияИнициалыФизЛица(Выборка.Кассир, Выборка.ДатаДокумента);
		
		ТабличныйДокумент.Вывести(ОбластьМакета);
		
		УправлениеПечатью.ЗадатьОбластьПечатиДокумента(
			ТабличныйДокумент,
			НомерСтрокиНачало,
			ОбъектыПечати,
			Выборка.Ссылка);
	КонецЦикла;
	
	ТабличныйДокумент.ДвусторонняяПечать = ТипДвустороннейПечати.ПереворотВлево;
	
	ТабличныйДокумент.АвтоМасштаб = Истина;
	
	Возврат ТабличныйДокумент;
	
КонецФункции

Функция КорреспондирующийСчет(ДанныеДокумента, КорСчета, ИспользуетсяРеглУчет)
	
	Отбор = Новый Структура("Ссылка", ДанныеДокумента.Ссылка);
	КорСчетаДокумента = КорСчета.НайтиСтроки(Отбор);
	Результат = "";
	Для Каждого Счет Из КорСчетаДокумента Цикл
		Результат = Результат + " " + СокрЛП(Счет.КорСчетКод);
	КонецЦикла;
	
	Если Результат = "" И Не ИспользуетсяРеглУчет Тогда
		СтатьяДвиженияДенежныхСредств = Справочники.СтатьиДвиженияДенежныхСредств.ПредопределеннаяСтатьяДДС(ДанныеДокумента.ХозяйственнаяОперация,
																											ДанныеДокумента.Валюта);
		Результат = СтатьяДвиженияДенежныхСредств.КорреспондирующийСчет;
	КонецЕсли;
	Возврат Результат;
	
КонецФункции


