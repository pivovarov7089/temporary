&НаСервере
Процедура ОбновитьПозиции()
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ЗаказКлиентаТовары.Номенклатура КАК Номенклатура,
		|	ЗаказКлиентаТовары.КоличествоУпаковок КАК КоличествоУпаковок,
		|	ЗаказКлиентаТовары.Количество КАК Количество
		|ИЗ
		|	Документ.Рейс.Заказы КАК РейсЗаказы
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ЗаказКлиента.Товары КАК ЗаказКлиентаТовары
		|		ПО РейсЗаказы.ЗаказКлиента = ЗаказКлиентаТовары.Ссылка
		|			И (РейсЗаказы.Ссылка = &Рейс)";
	
	Запрос.УстановитьПараметр("Рейс", Объект.Ссылка);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Позиции.Очистить();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		СтрокаПозиции = Позиции.Добавить();
		СтрокаПозиции.Номенклатура = ВыборкаДетальныеЗаписи.Номенклатура;
		СтрокаПозиции.КоличествоШт = ВыборкаДетальныеЗаписи.Количество;
		СтрокаПозиции.КоличествоУпак = ВыборкаДетальныеЗаписи.КоличествоУпаковок;
	КонецЦикла;
	
КонецПроцедуры

