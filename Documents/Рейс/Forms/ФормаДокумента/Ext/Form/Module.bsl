// Собираем данные по рейсу: реализации + реквизиты заказа
&НаСервереБезКонтекста
Функция ПолучитьДоставкиДляМаршрутногоЛиста(СсылкаРейса) Экспорт
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	Реализация.Ссылка КАК Реализация,
	|	Реализация.Номер КАК НомерРеализации,
	|	Реализация.Дата КАК ДатаРеализации,
	|	ЕСТЬNULL(Реализация.СуммаДокумента, 0) КАК СуммаДокумента,
	|	ЗаказКлиентаДок.Ссылка КАК ЗаказКлиента,
	|	ЗаказКлиентаДок.Комментарий КАК КомментарийЗаказа,
	|	ЗаказКлиентаДок.Партнер.Наименование КАК Клиент,
	|	ЗаказКлиентаДок.АдресДоставки КАК АдресЗаказа,
	|	ЗаказКлиентаДок.ФормаОплаты КАК ФормаОплаты,
	|	ЗаказКлиентаДок.Партнер.Комментарий КАК ПартнерКомментарий
	|ИЗ
	|	Документ.Рейс.Заказы КАК Рейс
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.РеализацияТоваровУслуг КАК Реализация
	|		ПО (Реализация.ЗаказКлиента = Рейс.ЗаказКлиента)
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ЗаказКлиента КАК ЗаказКлиентаДок
	|		ПО (ЗаказКлиентаДок.Ссылка = Рейс.ЗаказКлиента)
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Контрагенты КАК Контр
	|		ПО (ЗаказКлиентаДок.Контрагент = Контр.Ссылка)
	|ГДЕ
	|	Рейс.Ссылка = &Рейс
	|	И Реализация.Проведен
	|
	|УПОРЯДОЧИТЬ ПО
	|	ЗаказКлиентаДок.Номер,
	|	ЗаказКлиентаДок.Дата");
	
	Запрос.УстановитьПараметр("Рейс", СсылкаРейса);
	Выборка = Запрос.Выполнить().Выбрать();
	
	Возврат Выборка;
КонецФункции

// Сумму прописью (надёжно)
&НаСервереБезКонтекста
Функция СуммаПрописью(Сумма) Экспорт
	Попытка
		Возврат ЧислоПрописью(Сумма, "Л = ru_RU; ДП = Истина", "рубль,рубля,рублей, м,копейка,копейки,копеек, ж,2");
	Исключение
		
		Коп = Сумма * 100 % 100;
		Возврат Формат(Цел(Сумма), "ЧГ=0") + " рублей " + Формат(Коп, "ЧГ=2") + " копеек";
	КонецПопытки;
КонецФункции

Функция МакетМаршрутныйЛист()
	Возврат Документы.Рейс.ПолучитьМакет("МаршрутныйЛист");
КонецФункции

&НаСервере
Функция СформироватьТабДокМаршрутногоЛиста()
	
	// 1) Получаем данные с сервера
	Доставки = ПолучитьДоставкиДляМаршрутногоЛиста(Объект.Ссылка);
	
	Если Доставки.Количество() = 0 Тогда
		ВызватьИсключение("Нет проведённых реализаций по рейсу.");
	КонецЕсли;
	
	// 2) Макет
	Макет = МакетМаршрутныйЛист();
	ТД = Новый ТабличныйДокумент;
	
	// 3) Шапка
	ОблШапка = Макет.ПолучитьОбласть("Шапка");
	Заголовок = "Рейс " + Объект.ЗонаДоставки.Наименование + "  Дата рейса " + Формат(Объект.Дата, "ДЛФ=DD.MM.YY");
	ОблШапка.Параметры.Заголовок = Заголовок;
	ТД.Вывести(ОблШапка);
	
	ОблШапкаДоставки = Макет.ПолучитьОбласть("ШапкаДоставки");
	ТД.Вывести(ОблШапкаДоставки);
	
	// 4) Строки доставок
	НомерДоставки = 0;
	СуммаНаличными = 0;
	
	Пока Доставки.Следующий() Цикл
		НомерДоставки = НомерДоставки + 1;
		
		ОблСтр = Макет.ПолучитьОбласть("СтрокаДоставки");
		ОблСтр.Параметры.Номер = НомерДоставки;
		ОблСтр.Параметры.РеалНомерДата = 
		"№ " + Доставки.НомерРеализации + "  " + Формат(Доставки.ДатаРеализации, "ДЛФ=DD.MM.YY");
		ОблСтр.Параметры.Комментарий = Доставки.КомментарийЗаказа;
		ОблСтр.Параметры.Клиент = Доставки.Клиент;
		ОблСтр.Параметры.Адрес = Доставки.АдресЗаказа;
		ОблСтр.Параметры.КомментарийПартнера = Доставки.ПартнерКомментарий;
		ОблСтр.Параметры.Сумма = Формат(Доставки.СуммаДокумента, "ЧГ=0; ЧДЦ=2");
		Если Доставки.ФормаОплаты = Перечисления.ФормыОплаты.Наличная Тогда
			ОблСтр.Параметры.Наличные = Доставки.СуммаДокумента;
		КонецЕсли;
		
		ТД.Вывести(ОблСтр);
		
		Если Доставки.ФормаОплаты = Перечисления.ФормыОплаты.Наличная Тогда
			СуммаНаличными = СуммаНаличными + Доставки.СуммаДокумента;
		КонецЕсли;
	КонецЦикла;
	
	// 5) Итог (сумма наличными и прописью)
	ОблИтог = Макет.ПолучитьОбласть("Итог");
	ОблИтог.Параметры.СуммаНаличными = Формат(СуммаНаличными, "ЧГ=0; ЧДЦ=2");
	ОблИтог.Параметры.СуммаНаличнымиПрописью = СуммаПрописью(СуммаНаличными);
	ТД.Вывести(ОблИтог);
	Возврат ТД;
	
КонецФункции

