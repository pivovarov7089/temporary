Функция НайтиРеализацииПоЗаказуСервер(ЗаказКлиента) Экспорт
	Рез = Новый Массив;
	Если Не ЗначениеЗаполнено(ЗаказКлиента) Тогда 
		Возврат Рез; 
	КонецЕсли;
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|   Реал.Ссылка КАК Ссылка
	|ИЗ
	|   Документ.РеализацияТоваровУслуг КАК Реал
	|ГДЕ
	|   Реал.Проведен
	|   И Реал.ЗаказКлиента = &Заказ");
	Запрос.УстановитьПараметр("Заказ", ЗаказКлиента);
	Выб = Запрос.Выполнить().Выбрать();
	Пока Выб.Следующий() Цикл
		Рез.Добавить(Выб.Ссылка);
	КонецЦикла;
	
	Возврат Рез;
КонецФункции 

