&НаСервере
Функция ПочтаПоставщика()
	Возврат Константы.АдресПочтыПоставщика.Получить();
КонецФункции

&НаКлиенте
Процедура ОтпавитьДокументы(Команда)
	
	Если ЗначениеЗаполнено(Объект.ДатаОтправкиПоставщику) Тогда
		Сообщить("Уже отправлено: " + Формат(Объект.ДатаОтправкиПоставщику, "ДЛФ=DD.MM.YYYY HH:MM"));
		Возврат;
	КонецЕсли;
	Если Объект.Заказы.Количество() = 0 Тогда
		Сообщить("В рейсе нет заказов.");
		Возврат;
	КонецЕсли;
	
	Если ЭтотОбъект.Модифицированность Тогда
		Сообщить("Данный рейс изменен. Сначала запишите изменения, а после выполните формирование.");
		Возврат;
	КонецЕсли;
	
	
	Попытка
		ПолноеИмяФайла = СформироватьExcelИОтправитьSMTP(Объект.Ссылка, ПочтаПоставщика());
	Исключение
		Сообщить("Ошибка отправки: " + ОписаниеОшибки());
		Возврат;
	КонецПопытки;
	
	Объект.ДатаОтправкиПоставщику = ТекущаяДата();
	Объект.ДатаЛокальногоФормированияЗаявки = Дата(1, 1, 1);
	ЭтотОбъект.Записать(Новый Структура("РежимЗаписи", РежимЗаписиДокумента.Проведение));
	Сообщить("Отправлено. Файл: " + ПолноеИмяФайла);
КонецПроцедуры

&НаКлиенте
Процедура СформироватьЗаявкуБезОтправки(Команда)
	
	Если Объект.Заказы.Количество() = 0 Тогда
		Сообщить("В рейсе нет заказов.");
		Возврат;
	КонецЕсли;
	Если ЭтотОбъект.Модифицированность Тогда
		Сообщить("Сначала запишите рейс.");
		Возврат;
	КонецЕсли;
	Попытка
		ПолныйПуть = СформироватьЗаявкуБезОтправкиНаСервере(Объект.Ссылка);
		Сообщить(НСтр("ru = 'Заявка сформирована, поставщику не отправлялось. Файл: '") + ПолныйПуть);
		ЭтотОбъект.Прочитать();
	Исключение
		Сообщить(НСтр("ru = 'Ошибка: '") + ОписаниеОшибки());
	КонецПопытки;
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция СформироватьФайлExcelПоРейсу(СсылкаРейса) Экспорт
	
	Запрос = Новый Запрос("ВЫБРАТЬ
	|	ЗаказКлиентаТовары.Ссылка.Организация.Наименование КАК Организация,
	|	ЗаказКлиентаТовары.Номенклатура.Родитель.Наименование КАК Родитель,
	|	ЗаказКлиентаТовары.Номенклатура.Код КАК НоменклатураКод,
	|	СУММА(ЗаказКлиентаТовары.КоличествоУпаковок) КАК КоличествоУпаковок,
	|	ЗаказКлиентаТовары.Номенклатура.Наименование КАК НоменклатураНаименование,
	|	ЗаказКлиентаТовары.Упаковка.Наименование КАК НаименованиеУпаковки,
	|	ЗаказКлиентаТовары.Упаковка.Числитель КАК Числитель,
	|	ЗаказКлиентаТовары.Номенклатура.ЕдиницаИзмерения.Наименование КАК ЕдиницаИзмеренияНаименование,
	|	ЗаказКлиентаТовары.Ссылка.Организация.ИНН КАК ОрганизацияИНН,
	|	СУММА(ЗаказКлиентаТовары.Количество) КАК Количество
	//|	СУММА(ЗаказКлиентаТовары.КоличествоУпаковок * ЗаказКлиентаТовары.Упаковка.Числитель) КАК Количество
	|ИЗ
	|	Документ.Рейс.Заказы КАК РейсыЗаказы
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ЗаказКлиента.Товары КАК ЗаказКлиентаТовары
	|		ПО РейсыЗаказы.ЗаказКлиента = ЗаказКлиентаТовары.Ссылка
	|ГДЕ
	|	РейсыЗаказы.Ссылка = &Ссылка
	|
	|СГРУППИРОВАТЬ ПО
	|	ЗаказКлиентаТовары.Ссылка.Организация.Наименование,
	|	ЗаказКлиентаТовары.Номенклатура.Родитель.Наименование,
	|	ЗаказКлиентаТовары.Номенклатура.ЕдиницаИзмерения.Наименование,
	|	ЗаказКлиентаТовары.Номенклатура.Наименование,
	|	ЗаказКлиентаТовары.Номенклатура.Код,
	|	ЗаказКлиентаТовары.Ссылка.Организация.ИНН,
	|	ЗаказКлиентаТовары.Упаковка.Числитель,
	|	ЗаказКлиентаТовары.Упаковка.Наименование
	|ИТОГИ
	|	СУММА(КоличествоУпаковок),
	|	МАКСИМУМ(ОрганизацияИНН),
	|	СУММА(Количество)
	|ПО
	|	Организация,
	|	Родитель");
	Запрос.УстановитьПараметр("Ссылка", СсылкаРейса);
	
	Результат = Запрос.Выполнить();
	
	Возврат СформироватьExcelЧерезМакет(СсылкаРейса, Результат, СсылкаРейса.Номер);
	
КонецФункции

&НаСервереБезКонтекста
Функция СформироватьExcelИОтправитьSMTP(СсылкаРейса, Получатель) Экспорт
	
	ПолноеИмяФайла = СформироватьФайлExcelПоРейсу(СсылкаРейса);
	
	Тема = СсылкаРейса.ЗонаДоставки.Наименование + " от " + СсылкаРейса.Дата;
	ТекстПисьма = "Во вложении заказ по рейсу " + СсылкаРейса.Номер + Символы.ПС
	+ "От: " + Формат(СсылкаРейса.Номер, "ДЛФ=DD.MM.YY");
	ОтправитьЧерезSMTP(ПолноеИмяФайла, Тема, ТекстПисьма, Получатель);
	
	Возврат ПолноеИмяФайла;
КонецФункции

&НаСервере
Функция СформироватьЗаявкуБезОтправкиНаСервере(СсылкаРейса)
	
	ПолноеИмяФайла = СформироватьФайлExcelПоРейсу(СсылкаРейса);
	
	РейсОбъект = СсылкаРейса.ПолучитьОбъект();
	РейсОбъект.ДатаЛокальногоФормированияЗаявки = ТекущаяДатаСеанса();
	РейсОбъект.Записать(РежимЗаписиДокумента.Проведение);
	
	Возврат ПолноеИмяФайла;
	
КонецФункции

